# Public customer shop — no API key required for browse or checkout.
# Dev: Vite proxies /api/public → Cloud Functions (see vite.config.js).

# Leave empty to use same-origin /api/public (prod hosting) or dev proxy.
# VITE_API_BASE_URL=https://us-central1-jon-sport.cloudfunctions.net/publicApi

# Marketplace at http://localhost:5179/ lists ALL businesses from the platform API.
# Optional: force single-store on / (legacy dev only)
# VITE_SINGLE_STORE_DEV=true
# VITE_BUSINESS_SLUG=napoletana-nostra

# Optional: only for third-party API integrations (?key= in URL), NOT for customers
# VITE_API_KEY=

# Fallback display only if business has no orderPhone in admin
# VITE_ORDER_PHONE=+38344416502
